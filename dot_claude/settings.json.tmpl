{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git diff:*)",
      "Bash(git ls-tree:*)",
      "Bash(go build:*)",
      "Bash(go get:*)",
      "Bash(go mod init:*)",
      "Bash(grep:*)",
      "Bash(kustomize build:*)",
      "Bash(limactl create:*)",
      "Bash(limactl shell:*)",
      "Bash(limactl start:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)"
    ],
    "deny": []
  },
  "hooks": {
    "Notification": [
{{- if (eq .chezmoi.os "darwin") }}
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "DIR=$(basename \"$PWD\") && osascript -e \"display notification \\\"Claude Codeが許可を求めています\\\" with title \\\"Claude Code\\\" subtitle \\\"確認待ち - $DIR\\\" sound name \\\"Glass\\\"\""
          }
        ]
      }
{{- end }}
    ],
    "Stop": [
{{- if (eq .chezmoi.os "darwin") }}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "DIR=$(basename \"$PWD\") && osascript -e \"display notification \\\"タスクが完了しました\\\" with title \\\"Claude Code\\\" subtitle \\\"処理終了 - $DIR\\\" sound name \\\"Hero\\\"\""
          }
        ]
      }
{{- end }}
    ]
  },
  "statusLine": {
    "type": "command",
{{- if .isWork }}
    "command": "CLAUDE_STATUSLINE_NO_USAGE=1 bash ~/.claude/statusline.sh"
{{- else }}
    "command": "bash ~/.claude/statusline.sh"
{{- end }}
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "language": "japanese"
}
